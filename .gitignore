test-results/

# ---------------------------------------------------------------------------
# Generated reports (regenerated by every run).
# NOTE: snapshots/ is intentionally NOT ignored -- committed snapshots let the
# Streamlit Cloud demo render a full comparison even when live scraping is
# blocked. Remove the line below if you prefer to commit sample reports too.
# ---------------------------------------------------------------------------
reports/output/

